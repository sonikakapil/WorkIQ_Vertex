GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash

# Recommended: launch WorkIQ through npx so the repo stays self-contained
WORKIQ_USE_NPX=true
WORKIQ_NPX_PACKAGE=@microsoft/workiq@latest

# Optional alternative if you installed WorkIQ globally:
# WORKIQ_USE_NPX=false
# WORKIQ_COMMAND=workiq
# WORKIQ_ARGS=mcp